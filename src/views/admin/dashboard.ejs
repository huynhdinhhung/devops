<%- include('layout', { content: `
    <h4 class="fw-bold mb-4 text-gradient">Dashboard Overview</h4>
    
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card-premium p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3">
                        <i class="fas fa-users text-primary fa-xl"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Hội viên</div>
                        <h3 class="fw-bold mb-0">${stats.memberCount}</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-premium p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 p-3 rounded-4 me-3">
                        <i class="fas fa-dumbbell text-info fa-xl"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Thiết bị</div>
                        <h3 class="fw-bold mb-0">${stats.equipmentCount}</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-premium p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-4 me-3">
                        <i class="fas fa-wallet text-success fa-xl"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Doanh thu</div>
                        <h3 class="fw-bold mb-0">${Number(stats.totalRevenue).toLocaleString('vi-VN')} đ</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card-premium p-4">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-4 me-3">
                        <i class="fas fa-user-tie text-warning fa-xl"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">HLV</div>
                        <h3 class="fw-bold mb-0">${stats.trainerCount}</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 overflow-hidden">
        <div class="col-md-8">
            <div class="card-premium p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold mb-0">Thanh toán gần đây</h5>
                    <a href="/admin/reports/revenue" class="btn btn-sm btn-outline-primary rounded-pill px-3">Báo cáo</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="text-muted small table-light">
                            <tr>
                                <th>Hội viên</th>
                                <th>Số tiền</th>
                                <th>Mã giao dịch</th>
                                <th>Ngày</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${recentPayments.map(p => `
                                <tr>
                                    <td><div class="fw-bold">${p.member.user.fullName}</div></td>
                                    <td class="text-success fw-bold">+${Number(p.amount).toLocaleString('vi-VN')} đ</td>
                                    <td class="text-muted small">${p.transactionId}</td>
                                    <td class="text-muted small">${new Date(p.createdAt).toLocaleDateString('vi-VN')}</td>
                                </tr>
                            `).join('')}
                            ${recentPayments.length === 0 ? '<tr><td colspan="4" class="text-center py-4 text-muted">Chưa có thanh toán gần đây</td></tr>' : ''}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-premium p-4">
                <h5 class="fw-bold mb-4">Hội viên mới</h5>
                <div class="d-grid gap-3">
                    ${recentMembers.map(m => `
                        <div class="d-flex align-items-center">
                            <div class="bg-light rounded-circle p-3 me-3 text-center" style="width: 50px; height: 50px; display: flex; align-items: center; justify-content: center;">
                                <i class="fas fa-user text-muted"></i>
                            </div>
                            <div>
                                <div class="fw-bold">${m.user.fullName}</div>
                                <div class="text-muted small">Tham gia ${new Date(m.createdAt).toLocaleDateString('vi-VN')}</div>
                            </div>
                        </div>
                    `).join('')}
                    ${recentMembers.length === 0 ? '<div class="text-center py-4 text-muted">Chưa có hội viên mới</div>' : ''}
                </div>
                <hr class="opacity-10 my-4">
                <a href="/admin/members" class="btn btn-primary w-100 rounded-pill fw-bold">Tất cả Hội viên</a>
            </div>
        </div>
    </div>
` }) %>
