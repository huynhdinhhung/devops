<%- include('../layout', { content: `
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-5">
                <h4 class="fw-bold mb-4">Add New Equipment</h4>
                <form action="/admin/equipment/add" method="POST">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Equipment Name</label>
                            <input type="text" name="name" class="form-control" placeholder="e.g. Treadmill X1" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Type</label>
                            <select name="type" class="form-select" required>
                                <option value="Cardio">Cardio</option>
                                <option value="Strength">Strength</option>
                                <option value="Accessory">Accessory</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Purchase Date</label>
                            <input type="date" name="purchaseDate" class="form-control" value="${new Date().toISOString().split('T')[0]}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Next Maintenance</label>
                            <input type="date" name="nextMaintenance" class="form-control">
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description / Notes</label>
                        <textarea name="description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Register Equipment</button>
                        <a href="/admin/equipment" class="btn btn-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
` }) %>
