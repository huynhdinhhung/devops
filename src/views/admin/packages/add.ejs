<%- include('../layout', { content: `
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-5">
                <h4 class="fw-bold mb-4">Create New Package</h4>
                <form action="/admin/packages/add" method="POST">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Package Name</label>
                        <input type="text" name="packageName" class="form-control" placeholder="e.g. VIP 1 Year" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Package details..."></textarea>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Duration (Days)</label>
                            <input type="number" name="duration" class="form-control" placeholder="365" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Price (VNĐ)</label>
                            <input type="number" name="price" class="form-control" placeholder="1000000" required>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Create Package</button>
                        <a href="/admin/packages" class="btn btn-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
` }) %>
