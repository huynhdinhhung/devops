<%- include('../layout', { content: `
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-5">
                <h4 class="fw-bold mb-4">Edit Member Profile</h4>
                
                <form action="/admin/members/edit/${member._id}" method="POST">
                    <h6 class="text-primary fw-bold mb-3">Account Status</h6>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Full Name</label>
                            <input type="text" name="fullName" class="form-control" value="${member.user.fullName}" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="status" class="form-select">
                                <option value="Active" ${member.user.status === 'Active' ? 'selected' : ''}>Active</option>
                                <option value="Inactive" ${member.user.status === 'Inactive' ? 'selected' : ''}>Inactive</option>
                                <option value="Blocked" ${member.user.status === 'Blocked' ? 'selected' : ''}>Blocked</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Email</label>
                        <input type="email" name="email" class="form-control" value="${member.user.email}" required>
                    </div>

                    <h6 class="text-primary fw-bold mb-3 border-top pt-3">Profile Details</h6>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Birth Date</label>
                            <input type="date" name="birthDate" class="form-control" value="${member.birthDate ? new Date(member.birthDate).toISOString().split('T')[0] : ''}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Gender</label>
                            <select name="gender" class="form-select">
                                <option value="Male" ${member.gender === 'Male' ? 'selected' : ''}>Male</option>
                                <option value="Female" ${member.gender === 'Female' ? 'selected' : ''}>Female</option>
                                <option value="Other" ${member.gender === 'Other' ? 'selected' : ''}>Other</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input type="text" name="phone" class="form-control" value="${member.phone || ''}">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Address</label>
                            <input type="text" name="address" class="form-control" value="${member.address || ''}">
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Save Changes</button>
                        <a href="/admin/members" class="btn btn-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
` }) %>
