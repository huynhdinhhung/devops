<%- include('../layout', { content: `
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h4 class="fw-bold mb-1 text-gradient">Quản lý Hội viên</h4>
            <p class="text-muted small mb-0">Theo dõi danh sách và tình trạng đăng ký của các hội viên.</p>
        </div>
        <a href="/admin/members/add" class="btn btn-primary btn-premium shadow-sm">
            <i class="fas fa-user-plus me-2"></i>Thêm Hội viên
        </a>
    </div>

    <div class="card-premium p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light small text-uppercase">
                    <tr>
                        <th class="ps-3 border-0">Thông tin Hội viên</th>
                        <th class="border-0">Liên hệ</th>
                        <th class="border-0">Ngày Gia nhập</th>
                        <th class="border-0">Trạng thái</th>
                        <th class="border-0 text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    ${members.map(m => `
                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle p-2 me-3 text-center" style="width: 40px; height: 40px;">
                                        <i class="fas fa-user text-muted"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-primary">${m.user.fullName}</div>
                                        <div class="text-muted small">@${m.user.username}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div><i class="fas fa-envelope me-2 text-muted small"></i>${m.user.email}</div>
                                <div class="text-muted small"><i class="fas fa-phone me-2 text-muted small"></i>${m.phone || 'N/A'}</div>
                            </td>
                            <td class="text-muted small">
                                <i class="fas fa-calendar-check me-1"></i>
                                ${new Date(m.createdAt).toLocaleDateString('vi-VN')}
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-${m.user.status === 'Active' ? 'success' : m.user.status === 'Blocked' ? 'danger' : 'secondary'} bg-opacity-10 text-${m.user.status === 'Active' ? 'success' : m.user.status === 'Blocked' ? 'danger' : 'secondary'} p-2 px-3 fw-bold">
                                    ${m.user.status === 'Active' ? 'Hoạt động' : m.user.status === 'Blocked' ? 'Đã khóa' : 'Chờ'}
                                </span>
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-2">
                                    <a href="/admin/members/edit/${m._id}" class="btn btn-sm btn-light rounded-circle p-2 hover-float">
                                        <i class="fas fa-edit text-primary"></i>
                                    </a>
                                    <form action="/admin/members/${m._id}?_method=DELETE" method="POST" onsubmit="return confirm('Xác nhận xóa hội viên này?')">
                                        <button class="btn btn-sm btn-light rounded-circle p-2 hover-float">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    `).join('')}
                    ${members.length === 0 ? '<tr><td colspan="5" class="text-center py-5 text-muted">Không tìm thấy hội viên nào trong hệ thống</td></tr>' : ''}
                </tbody>
            </table>
        </div>
    </div>
` }) %>
