<%- include('../layout', { content: `
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card p-5">
                <h4 class="fw-bold mb-4">Create New Training Session</h4>
                <form action="/admin/schedules/add" method="POST">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Select Member</label>
                            <select name="member" class="form-select" required>
                                ${members.map(m => `<option value="${m._id}">${m.user.fullName} (@${m.user.username})</option>`).join('')}
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Select Trainer</label>
                            <select name="trainer" class="form-select" required>
                                ${trainers.map(t => `<option value="${t._id}">${t.user.fullName} (${t.specialization})</option>`).join('')}
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Start Time</label>
                            <input type="datetime-local" name="startTime" class="form-control" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">End Time</label>
                            <input type="datetime-local" name="endTime" class="form-control" required>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Description / Notes</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Session goals, equipment needed..."></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Create Session</button>
                        <a href="/admin/schedules" class="btn btn-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
` }) %>
