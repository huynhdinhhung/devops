<%- include('../layout', { content: `
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h4 class="fw-bold mb-1 text-gradient">Quản lý Huấn luyện viên</h4>
            <p class="text-muted small mb-0">Danh sách các chuyên gia hướng dẫn tập luyện tại phòng tập.</p>
        </div>
        <a href="/admin/trainers/add" class="btn btn-primary btn-premium shadow-sm">
            <i class="fas fa-user-plus me-2"></i>Thêm HLV
        </a>
    </div>

    <div class="card-premium p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light small text-uppercase">
                    <tr>
                        <th class="ps-3 border-0">Huấn luyện viên</th>
                        <th class="border-0">Chuyên môn</th>
                        <th class="border-0">Chứng chỉ</th>
                        <th class="border-0">Ngày vào làm</th>
                        <th class="border-0 text-end pe-3">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    ${trainers.map(t => `
                        <tr>
                            <td class="ps-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-indigo bg-opacity-10 text-indigo rounded-circle p-2 me-3 text-center" style="width: 40px; height: 40px;">
                                        <i class="fas fa-user-tie"></i>
                                    </div>
                                    <div>
                                        <div class="fw-bold text-primary">${t.user.fullName}</div>
                                        <div class="text-muted small">${t.user.email}</div>
                                    </div>
                                </div>
                            </td>
                            <td><span class="badge bg-indigo bg-opacity-10 text-indigo px-3 rounded-pill">${t.specialization || 'Chưa cập nhật'}</span></td>
                            <td class="small text-muted"><i class="fas fa-certificate me-1"></i>${t.certificate || 'N/A'}</td>
                            <td class="small text-muted">
                                <i class="fas fa-calendar-alt me-1"></i>
                                ${new Date(t.hireDate).toLocaleDateString('vi-VN')}
                            </td>
                            <td class="text-end pe-3">
                                <div class="d-flex justify-content-end gap-2">
                                    <form action="/admin/trainers/${t._id}?_method=DELETE" method="POST" onsubmit="return confirm('Xác nhận xóa huấn luyện viên này?')">
                                        <button class="btn btn-sm btn-light rounded-circle p-2 hover-float">
                                            <i class="fas fa-trash-alt text-danger"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    `).join('')}
                    ${trainers.length === 0 ? '<tr><td colspan="5" class="text-center py-5 text-muted">Không tìm thấy huấn luyện viên nào trong hệ thống</td></tr>' : ''}
                </tbody>
            </table>
        </div>
    </div>
` }) %>
