<%- include('../shared/header') %>

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold"><i class="fas fa-calendar-alt me-2 text-primary"></i>Lịch Dạy Của Tôi</h2>
    </div>

    <div class="card border-0 shadow-sm rounded-4 p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Hội viên / Học viên</th>
                        <th>Ngày & Giờ</th>
                        <th>Trạng thái</th>
                        <th>Ghi chú</th>
                    </tr>
                </thead>
                <tbody>
                    <% schedules.forEach(s => { %>
                        <tr>
                            <td>
                                <div class="fw-bold"><%= s.member.user.fullName %></div>
                                <div class="text-muted small"><%= s.member.phone || 'Chưa có SĐT' %></div>
                            </td>
                            <td>
                                <div class="fw-bold"><%= new Date(s.startTime).toLocaleDateString() %></div>
                                <div class="text-muted small">
                                    <%= new Date(s.startTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> - 
                                    <%= new Date(s.endTime).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                </div>
                            </td>
                            <td>
                                <span class="badge bg-<%= s.status === 'Scheduled' ? 'primary' : s.status === 'Completed' ? 'success' : 'danger' %>">
                                    <%= s.status === 'Scheduled' ? 'Đã lên lịch' : s.status === 'Completed' ? 'Hoàn thành' : 'Đã hủy' %>
                                </span>
                            </td>
                            <td>
                                <small class="text-muted"><%= s.description || '-' %></small>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (schedules.length === 0) { %>
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">Bạn hiện chưa có lịch dạy nào.</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('../shared/footer') %>
