<%- include('../shared/header') %>

<main class="container py-5">
    <div class="text-center mb-5">
        <h2 class="display-5 fw-bold">Tin Tức & <span class="text-gradient">Kiến Thức</span></h2>
        <p class="text-muted">Cập nhật những tin tức mới nhất và lời khuyên tập luyện từ chuyên gia.</p>
    </div>

    <div class="row g-4 overflow-hidden">
        <% posts.forEach(p => { %>
            <div class="col-md-4">
                <div class="card-premium h-100 overflow-hidden">
                    <% if (p.image) { %>
                        <img src="<%= p.image %>" class="card-img-top" alt="<%= p.title %>" style="height: 200px; object-fit: cover;">
                    <% } else { %>
                        <div class="bg-light text-center py-5">
                            <i class="fas fa-image fa-3x text-muted opacity-25"></i>
                        </div>
                    <% } %>
                    <div class="card-body p-4">
                        <span class="badge bg-primary bg-opacity-10 text-primary mb-2"><%= p.category %></span>
                        <h5 class="fw-bold"><%= p.title %></h5>
                        <p class="text-muted small mb-4"><%= p.content.substring(0, 100) %>...</p>
                        <hr class="opacity-10">
                        <div class="d-flex justify-content-between align-items-center">
                            <div class="small text-muted">
                                <i class="fas fa-calendar-alt me-1"></i> <%= new Date(p.createdAt).toLocaleDateString('vi-VN') %>
                            </div>
                            <a href="/news/<%= p._id %>" class="btn btn-sm btn-link fw-bold text-decoration-none text-primary">Xem chi tiết <i class="fas fa-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
        <% if (posts.length === 0) { %>
            <div class="col-12 text-center py-5">
                <p class="text-muted">Hiện chưa có bài viết nào.</p>
            </div>
        <% } %>
    </div>
</main>

<%- include('../shared/footer') %>
