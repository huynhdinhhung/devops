<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | GymManage Portal</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary-bg: #0f172a;
            --sidebar-width: 280px;
            --accent-color: #6366f1;
            --card-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
        }
        body { 
            font-family: 'Plus Jakarta Sans', sans-serif; 
            background-color: #f8fafc; 
            color: #1e293b;
            overflow-x: hidden;
        }
        .sidebar { 
            width: var(--sidebar-width); 
            height: 100vh; 
            position: fixed; 
            background: var(--primary-bg); 
            color: white;
            z-index: 1000;
            transition: all 0.3s ease;
        }
        .main-content { 
            margin-left: var(--sidebar-width); 
            padding: 2.5rem;
            min-height: 100vh;
        }
        .nav-link { 
            color: #94a3b8; 
            padding: 0.8rem 1.5rem; 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            transition: all 0.3s;
            border-radius: 10px;
            margin: 0.2rem 1rem;
        }
        .nav-link:hover, .nav-link.active { 
            background: rgba(99, 102, 241, 0.15); 
            color: #818cf8; 
            font-weight: 600;
        }
        .card { 
            border: none; 
            border-radius: 20px; 
            box-shadow: var(--card-shadow); 
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
        .portal-header {
            background: white;
            padding: 1rem 2.5rem;
            margin: -2.5rem -2.5rem 2.5rem -2.5rem;
            box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .user-badge {
            background: #f1f5f9;
            padding: 0.5rem 1rem;
            border-radius: 50px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>
<body>
    <div class="sidebar py-4 d-none d-lg-block">
        <div class="px-4 mb-5">
            <h4 class="fw-bold text-white"><i class="fas fa-dumbbell text-accent me-2"></i>GymManage</h4>
        </div>
        
        <nav class="nav flex-column gap-1">
            <%- sidebar %>
        </nav>

        <div class="position-absolute bottom-0 w-100 p-4">
            <a href="/auth/logout" class="nav-link text-danger border border-danger-subtle bg-danger bg-opacity-10 justify-content-center">
                <i class="fas fa-sign-out-alt"></i> Đăng xuất
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="portal-header">
            <h4 class="fw-bold m-0"><%= title %></h4>
            <div class="user-badge">
                <div class="text-end me-2 d-none d-md-block">
                    <div class="fw-bold small"><%= user.fullName %></div>
                    <div class="text-muted" style="font-size: 0.7rem;"><%= user.role %></div>
                </div>
                <img src="https://ui-avatars.com/api/?name=<%= user.fullName %>&background=6366f1&color=fff" class="rounded-circle" width="35" alt="User">
            </div>
        </div>

        <%- content %>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
