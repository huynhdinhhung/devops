<%- include('shared/header') %>

<main class="container py-5">
    <% if (success) { %>
        <div class="alert alert-success alert-dismissible fade show card-premium border-0 shadow-lg text-success mb-4 p-4" role="alert">
            <div class="d-flex align-items-center">
                <i class="fas fa-check-circle fa-2x me-3"></i>
                <div>
                    <h5 class="fw-bold mb-0">Thanh toán thành công!</h5>
                    <div>Gói tập của bạn đã được kích hoạt. Hãy bắt đầu tập luyện ngay!</div>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <div class="row g-4">
        <!-- Sidebar / Profile Info -->
        <div class="col-md-4">
            <div class="card-premium p-4 text-center">
                <div class="mb-4 hover-float d-inline-block">
                    <div class="bg-primary bg-opacity-10 p-4 rounded-circle">
                        <i class="fas fa-user-circle fa-5x text-primary"></i>
                    </div>
                </div>
                <h3 class="fw-bold mb-1"><%= member.user.fullName %></h3>
                <p class="text-muted">@<%= member.user.username %></p>
                <div class="badge rounded-pill bg-<%= member.user.status === 'Active' ? 'success' : 'danger' %> bg-opacity-10 text-<%= member.user.status === 'Active' ? 'success' : 'danger' %> p-2 px-3 mb-4">
                    <i class="fas fa-circle me-1 small"></i> <%= member.user.status === 'Active' ? 'Đang hoạt động' : 'Đã khóa' %>
                </div>
                <hr class="opacity-10 my-4">
                <div class="text-start space-y-3">
                    <div class="mb-3">
                        <div class="text-muted small fw-bold text-uppercase">Email chính thức</div>
                        <div class="fw-bold"><%= member.user.email %></div>
                    </div>
                    <div class="mb-3">
                        <div class="text-muted small fw-bold text-uppercase">Số điện thoại</div>
                        <div class="fw-bold"><%= member.phone || 'Chưa cung cấp' %></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-md-8">
            <!-- Membership Status Card -->
            <div class="card-premium p-4 mb-4">
                <h5 class="fw-bold mb-4">Gói Hội Viên Hiện Tại</h5>
                <% if (activeSubscription) { %>
                    <div class="hero-section p-4 text-white shadow-sm overflow-hidden">
                        <div class="row align-items-center position-relative" style="z-index: 1;">
                            <div class="col-md-8">
                                <h4 class="fw-bold mb-1"><%= activeSubscription.package.packageName %></h4>
                                <div class="opacity-75"><i class="fas fa-calendar-alt me-2"></i>Hết hạn: <%= new Date(activeSubscription.endDate).toLocaleDateString('vi-VN') %></div>
                            </div>
                            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                <span class="badge bg-white text-primary fw-bold p-2 px-3 rounded-pill">ĐANG HOẠT ĐỘNG</span>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <div class="text-center py-5 bg-light rounded-4">
                        <i class="fas fa-id-card text-muted fa-3x mb-3 opacity-25"></i>
                        <p class="text-muted border-bottom pb-3 mx-5">Bạn chưa đăng ký bất kỳ gói tập nào trong thời điểm này.</p>
                        <a href="/packages" class="btn btn-primary btn-premium mt-3 px-5">Tham gia ngay</a>
                    </div>
                <% } %>
            </div>

            <div class="row g-4">
                <!-- Training Sessions Card -->
                <div class="col-12">
                    <div class="card-premium p-0 overflow-hidden">
                        <div class="p-4 border-bottom">
                            <h5 class="fw-bold mb-0">Lịch Tập Của Tôi</h5>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Huấn luyện viên</th>
                                        <th>Thời gian</th>
                                        <th class="pe-4">Trạng thái</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (schedules.length > 0) { %>
                                        <% schedules.forEach(s => { %>
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="fw-bold text-primary"><%= s.trainer.user.fullName %></div>
                                                    <div class="text-muted small"><%= s.trainer.specialization %></div>
                                                </td>
                                                <td>
                                                    <div class="fw-bold"><%= new Date(s.startTime).toLocaleDateString('vi-VN') %></div>
                                                    <div class="text-muted small"><%= new Date(s.startTime).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'}) %></div>
                                                </td>
                                                <td class="pe-4">
                                                    <span class="badge rounded-pill bg-<%= s.status === 'Scheduled' ? 'primary' : s.status === 'Completed' ? 'success' : 'danger' %> bg-opacity-10 text-<%= s.status === 'Scheduled' ? 'primary' : s.status === 'Completed' ? 'success' : 'danger' %> p-2 px-3">
                                                        <%= s.status === 'Scheduled' ? 'Đã lên lịch' : s.status === 'Completed' ? 'Hoàn thành' : 'Đã hủy' %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3" class="text-center py-5 text-muted small">Chưa có lịch tập nào được lên.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Payment History Card -->
                <div class="col-12">
                    <div class="card-premium p-0 overflow-hidden mb-4">
                        <div class="p-4 border-bottom">
                            <h5 class="fw-bold mb-0">Lịch Sử Giao Dịch</h5>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Giao dịch</th>
                                        <th>Số tiền</th>
                                        <th>Trạng thái</th>
                                        <th class="pe-4">Ngày</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (payments && payments.length > 0) { %>
                                        <% payments.forEach(p => { %>
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="fw-bold">Thanh toán Momo</div>
                                                    <div class="text-muted small"><%= p.transactionId %></div>
                                                </td>
                                                <td class="fw-bold text-success">+<%= Number(p.amount).toLocaleString('vi-VN') %> đ</td>
                                                <td>
                                                    <span class="badge rounded-pill bg-<%= p.status === 'Success' ? 'success' : 'warning' %> bg-opacity-10 text-<%= p.status === 'Success' ? 'success' : 'warning' %> p-2 px-3">
                                                        <%= p.status === 'Success' ? 'Hoàn tất' : 'Chờ xử lý' %>
                                                    </span>
                                                </td>
                                                <td class="pe-4 small text-muted"><%= new Date(p.createdAt).toLocaleDateString('vi-VN') %></td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="4" class="text-center py-5 text-muted small">Chưa có lịch sử giao dịch nào.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('shared/footer') %>
